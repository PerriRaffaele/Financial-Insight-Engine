# --- Data & Vector Database (CRITICAL) ---
# We do not want to commit the PDFs or the heavy Vector DB to GitHub.
data/raw_pdfs/*
data/vector_db/*

# ...But we DO want to keep the folder structure.
# (See instruction below on how to use .gitkeep)
!data/raw_pdfs/.gitkeep
!data/vector_db/.gitkeep

# --- IDE Settings ---
.vscode/
.idea/
*.swp

